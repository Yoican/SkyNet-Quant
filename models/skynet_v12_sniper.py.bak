import os
import sys
import json
import torch
import numpy as np
import pandas as pd
import warnings
warnings.filterwarnings('ignore')

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
FEATURES_DIR = os.path.join(BASE_DIR, "v12_features")
PORTFOLIO_PATH = os.path.join(BASE_DIR, "skynet_portfolio.json")
UNIVERSE_PATH = os.path.join(BASE_DIR, "skynet_universe.json")
MODEL_PATH = os.path.join(BASE_DIR, "v12_st_transformer.pth")

# 引入模型架构
from v12_st_model import SpatialTemporalTransformer
from v12_st_pipeline import FEATURE_COLS, SEQ_LEN

# V12 机器寻优确定的实盘参数
BULLET_SIZE = 2500.0
FEE_MIN = 5.0
BUY_Z_TH = 1.0      # 跑赢大盘 1.0 个标准差开枪
SELL_Z_TH = -0.5    # 跑输大盘 0.5 个标准差撤退

def load_portfolio():
    if os.path.exists(PORTFOLIO_PATH):
        with open(PORTFOLIO_PATH, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {"cash": 10000.0, "positions_in_shares": {}}

def load_universe():
    if os.path.exists(UNIVERSE_PATH):
        with open(UNIVERSE_PATH, 'r', encoding='utf-8') as f:
            return json.load(f).get('assets', {})
    return {}

def get_latest_spatial_temporal_tensor():
    """获取全市场最后 30 天的高维特征张量"""
    symbols = []
    raw_dfs = {}
    
    # 获取所有有效的 ETF
    for filename in sorted(os.listdir(FEATURES_DIR)):
        if filename.endswith(".csv"):
            sym = filename.replace('.csv', '')
            df = pd.read_csv(os.path.join(FEATURES_DIR, filename))
            df['date'] = pd.to_datetime(df['date'])
            df = df.dropna(subset=FEATURE_COLS).set_index('date')
            if len(df) >= SEQ_LEN:
                symbols.append(sym)
                raw_dfs[sym] = df.iloc[-SEQ_LEN:] # 只取最后 30 天
                
    if not symbols:
        return None, None, None
        
    num_assets = len(symbols)
    panel_features = np.zeros((SEQ_LEN, num_assets, len(FEATURE_COLS)))
    current_prices = np.zeros(num_assets)
    
    for i, sym in enumerate(symbols):
        df_sym = raw_dfs[sym]
        panel_features[:, i, :] = df_sym[FEATURE_COLS].values
        current_prices[i] = df_sym['close'].iloc[-1]
        
    # 全局 Z-Score 归一化 (与训练时保持一致)
    mean = np.nanmean(panel_features, axis=(0, 1), keepdims=True)
    std = np.nanstd(panel_features, axis=(0, 1), keepdims=True) + 1e-8
    panel_features = (panel_features - mean) / std
    
    # 转换为模型需要的 [Batch=1, Assets, Time, Features]
    window_x = np.transpose(panel_features, (1, 0, 2)) # [Assets, Time, Features]
    tensor_x = torch.tensor(window_x, dtype=torch.float32).unsqueeze(0)
    
    return tensor_x, symbols, current_prices

def main():
    print("\n" + "="*60)
    print(" 🎯 [SkyNet V12 Deep Sniper] 重工业时空执行层启动")
    print("="*60)
    
    tensor_x, symbols, current_prices = get_latest_spatial_temporal_tensor()
    if tensor_x is None:
        print("❌ 特征数据不足，无法构建时空张量！")
        return
        
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    model = SpatialTemporalTransformer(num_assets=len(symbols)).to(device)
    
    if os.path.exists(MODEL_PATH):
        model.load_state_dict(torch.load(MODEL_PATH, map_location=device))
        model.eval()
    else:
        print("❌ 找不到 ST-Transformer 模型权重文件！")
        return
        
    # 1. 大脑推理，吐出原始预测轨道
    with torch.no_grad():
        preds = model(tensor_x.to(device)).squeeze(0).cpu().numpy() # [Assets, 3] (T+1, T+3, T+5)
        
    # 2. 截面 Z-Score 转换 (让绝对数值变成相对排名)
    t3_raw = preds[:, 1]
    t5_raw = preds[:, 2]
    
    t3_z = (t3_raw - np.mean(t3_raw)) / (np.std(t3_raw) + 1e-8)
    t5_z = (t5_raw - np.mean(t5_raw)) / (np.std(t5_raw) + 1e-8)
    
    portfolio = load_portfolio()
    universe = load_universe()
    cash = portfolio.get('cash', 0)
    positions = portfolio.get('positions_in_shares', {})
    
    print(f" 💰 军火库现金: ￥{cash:.2f}")
    
    # 组装预测字典
    results = []
    for i, sym in enumerate(symbols):
        results.append({
            'symbol': sym,
            'name': universe.get(sym, {}).get('name', '未知'),
            'price': current_prices[i],
            't3_z': t3_z[i],
            't5_z': t5_z[i],
            't5_raw': t5_raw[i] # 用于算手续费期望
        })
        
    # 按 T+5 的 Z-Score 降序排列 (找出尖子生)
    results.sort(key=lambda x: x['t5_z'], reverse=True)
    
    print("\n【V12 截面相对强弱排行榜 TOP 5】")
    for i, r in enumerate(results[:5]):
        print(f" {i+1}. {r['name']:<10} ({r['symbol']}) | Z-Score: {r['t5_z']:>5.2f} 标准差 | 预期绝对涨幅: {r['t5_raw']*100:>5.2f}%")
        
    print("\n" + "-"*60)
    print(" 🚨 [系统执行层指令] (T+3锁仓 | Z-Score截面 | Net EV校验)")
    print("-" * 60)
    
    actions = []
    
    # --- 卖出防守闭环 ---
    held_symbols = [sym for sym, shares in positions.items() if shares > 0]
    for r in results:
        if r['symbol'] in held_symbols:
            # 模拟获取持仓天数 (实盘应从 portfolio 或 state 里读取，这里假定已过锁定期以供测试)
            days_held = 4 
            
            if days_held >= 3 and r['t5_z'] <= SELL_Z_TH:
                actions.append(f" 💥 [清仓退坡] {r['name']} Z-Score 跌至 {r['t5_z']:.2f} (阈值 {SELL_Z_TH})。趋势跑输大盘，卖出回收子弹！")
            elif days_held < 3:
                actions.append(f" 🛡️ [冷却期锁仓] {r['name']} 仍在 T+3 保护期内，无视波动死拿。")
            else:
                actions.append(f" 💤 [持仓装死] {r['name']} Z-Score 正常 ({r['t5_z']:.2f})，未触发卖出线，继续持有。")

    # --- 进攻打靶闭环 (Top-2) ---
    buy_count = 0
    for r in results:
        if r['symbol'] not in held_symbols and r['t5_z'] >= BUY_Z_TH and r['t3_z'] > 0:
            if buy_count >= 2: continue # 每天最多打 2 颗子弹
            
            expected_profit = BULLET_SIZE * r['t5_raw']
            net_profit = expected_profit - (FEE_MIN * 2)
            
            if net_profit > 0 and cash >= (BULLET_SIZE + FEE_MIN):
                shares = int(BULLET_SIZE / r['price'])
                cost = shares * r['price']
                actions.append(f" 🟢 [做多开枪] {r['name']} Z-Score高达 {r['t5_z']:.2f}！共振确认，净利校验通过(￥{net_profit:.1f})，买入 {shares} 股 (￥{cost:.2f})！")
                cash -= (cost + FEE_MIN)
                buy_count += 1
            elif cash < (BULLET_SIZE + FEE_MIN):
                actions.append(f" 🟡 [弹药不足] {r['name']} 满足开枪条件，但现金不足以打出标准子弹！")
            else:
                actions.append(f" 🔴 [EV锁死] {r['name']} Z-Score 极高，但预测绝对利润(￥{expected_profit:.1f})无法覆盖 10 元双边手续费！系统锁死。")
                
    if not actions:
        print(" 💤 结论：今日无任何触发交易的标的，账户进入完全休眠。")
    else:
        for act in actions:
            print(act)

if __name__ == '__main__':
    main()